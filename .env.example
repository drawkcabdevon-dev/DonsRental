# ── Vertex AI ──
VERTEX_AI_PROJECT=onlineeverywhere
VERTEX_AI_LOCATION=us-central1

# ── Required API Keys ──
GEMINI_API_KEY=your_key_here         # from https://aistudio.google.com
SENDGRID_API_KEY=your_key_here       # from https://sendgrid.com
SPREADSHEET_ID=your_sheet_id         # from Google Sheet URL
GOOGLE_SHEETS_CREDENTIALS={"type":"service_account",...}  # full JSON, one line

# ── Optional ──
COMPANY_NAME=Don's Rental
COMPANY_EMAIL=bookings@donsrental.com
COMPANY_PHONE=+1 (555) 000-0000
OWNER_EMAIL=you@example.com
NTFY_TOPIC=donsrental-bookings      # push notifications via https://ntfy.sh
